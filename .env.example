# ─────────────────────────────────────────────────────────────
# ABAP Modernization Copilot — environment configuration
# Copy this file to ".env.local" and fill in your values.
# ─────────────────────────────────────────────────────────────

# Anthropic API key. When set, scans/reports/chat are powered by
# real Claude calls. When ABSENT, the app runs in deterministic
# DEMO MODE using the built-in mock engine — so the public demo
# works end-to-end with no key and no cost.
ANTHROPIC_API_KEY=

# Claude model id (optional — defaults to a current Claude model).
ANTHROPIC_MODEL=claude-opus-4-8

# Force demo/mock mode even if a key is present (optional: "1" to force).
FORCE_DEMO_MODE=
